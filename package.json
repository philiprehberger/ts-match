{
  "name": "@philiprehberger/match-ts",
  "version": "0.1.0",
  "description": "Pattern matching for TypeScript — switch on steroids",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pattern-matching",
    "match",
    "switch",
    "exhaustive",
    "discriminated-union",
    "typescript"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-match.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-match#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-match/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
